# Copy to backend/.env and fill in values. Do not commit backend/.env.
# ASP.NET Core maps __ to nested config (Jwt__Secret -> Jwt:Secret).

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=aicontentflow;Username=postgres;Password=CHANGE_ME

# JWT
Jwt__Secret=CHANGE_ME_min_32_chars
Jwt__Issuer=AiContentFlow
Jwt__Audience=AiContentFlow

# Meta / Facebook
Meta__AppId=
Meta__AppSecret=
Meta__RedirectUri=http://localhost:5073/api/auth/facebook/callback

# LinkedIn
LinkedIn__ClientId=
LinkedIn__ClientSecret=
LinkedIn__RedirectUri=http://localhost:5073/api/auth/linkedin/callback

# Instagram (optional separate app; falls back to Meta)
Instagram__AppId=
Instagram__AppSecret=
Instagram__RedirectUri=http://localhost:5073/api/auth/instagram/callback

# Threads (HTTPS required)
Threads__AppId=
Threads__AppSecret=
Threads__RedirectUri=https://localhost:7075/api/auth/threads/callback

# Optional — only if AI:ProviderMode=ExternalProviders or Brand Studio extraction
Groq__ApiKey=
OpenAI__ApiKey=
Gemini__ApiKey=

# Optional — SMTP (password reset / invitations)
EmailSettings__SmtpServer=smtp.example.com
EmailSettings__SmtpPort=587
EmailSettings__SenderName=AiContentFlow
EmailSettings__SenderEmail=noreply@example.com
EmailSettings__Username=noreply@example.com
EmailSettings__Password=
